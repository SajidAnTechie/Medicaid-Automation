# Postgres
POSTGRES_DB=sentinel_state
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Analyst routing threshold
ANALYST_CONFIDENCE_THRESHOLD=85

# Drift governance: strict | balanced | lenient
DRIFT_POLICY=strict

# If true, forced-review cases are auto-rejected (no load).
BLOCK_ON_REVIEW=true

# Runtime mode: local | aws | hybrid
# local  -> write artifacts/checkpoints to local filesystem and log HITL alerts
# aws    -> use S3/SNS/DynamoDB when configured
# hybrid -> prefer AWS services but gracefully fallback to local
RUNTIME_MODE=local
PIPELINE_VERSION=sentinel-state-v2

# Optional AWS architecture integration (used when RUNTIME_MODE=aws|hybrid)
BRONZE_BUCKET=
SILVER_BUCKET=
CHECKPOINT_TABLE_NAME=
HITL_SNS_TOPIC_ARN=

# Local fallbacks used when AWS integrations are disabled/unavailable
DATA_LAKE_ROOT=data_lake
LOCAL_CHECKPOINT_DIR=checkpoints

# Bedrock mode. Set USE_BEDROCK=true for AWS Bedrock fallback/support,
# or set LLM_PROVIDER=bedrock to force Bedrock as primary.
USE_BEDROCK=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# Optional standard AWS env aliases (supported by most SDK tooling)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Bedrock Agent Runtime mode (invoke_agent)
# If USE_BEDROCK_AGENT=true and IDs are set, provider chain can use bedrock_agent.
USE_BEDROCK_AGENT=false
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_AGENT_SESSION_ID=sentinel-session

# LLM provider selection — primary provider tried first.
# Available providers: bedrock_agent | groq | gemini | openai | ollama | bedrock
# Fallback order uses only configured providers.
# Examples:
#   LLM_PROVIDER=groq      -> Groq primary, then other configured providers
#   LLM_PROVIDER=bedrock   -> Bedrock primary
#   LLM_PROVIDER=bedrock_agent -> Bedrock Agent Runtime primary
#   LLM_PROVIDER=          -> auto mode; Bedrock becomes primary if USE_BEDROCK=true
LLM_PROVIDER=groq            # change to bedrock_agent/groq/openai/ollama/bedrock as needed
LLM_MODEL=llama-3.3-70b-versatile  # overrides model for the PRIMARY provider only

# Per-provider model overrides — used when that provider is active (primary or fallback)
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.2

# Optional: set explicit fallback order (comma-separated, only configured providers used)
# LLM_FALLBACK_CHAIN=groq,gemini,openai

# Groq — free tier at console.groq.com (default model: llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_...

# Google Gemini — free tier at aistudio.google.com (default model: gemini-2.0-flash)
GEMINI_API_KEY=AIza...

# OpenAI — platform.openai.com (default model: gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Fallback behaviour: set multiple keys above and the system will try
# LLM_PROVIDER first, then auto-rotate through configured providers (including bedrock_agent when enabled)
# until one succeeds. Both LLM calls (business analyst + column mapping) run in parallel.

# Optional HITL dashboard:
# docker compose --profile hitl up --build
