# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Medicaid Automation — Pipeline Dashboard                                   ║
# ║  Environment Variables                                                      ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and fill in the values for your environment.        ║
# ║  All variables are VITE_-prefixed so Vite exposes them to the browser.      ║
# ║  ⚠️  NEVER commit the real .env file — only this .env.example.              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── 1. AWS Cognito (Authentication) ──────────────────────────────────────────
#
#   Create a Cognito User Pool + App Client with:
#     • OAuth2 grant type: Authorization Code
#     • Allowed callback URL: https://<your-domain>/callback
#     • Allowed sign-out URL:  https://<your-domain>
#     • Scopes: openid, email, profile
#
VITE_COGNITO_USER_POOL_ID=eu-north-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=https://your-auth-domain.auth.eu-north-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=https://your-dashboard-domain.com/callback
VITE_COGNITO_LOGOUT_URI=https://your-dashboard-domain.com

# ── 2. AgentCore Endpoint URLs ───────────────────────────────────────────────
#
#   Each agent is deployed as a separate AgentCore container.
#   The URL format is typically:
#     https://<agentcore-host>/agents/<agent-name>/invocations
#
#   Leave ALL four blank to enable dev-mode mock stubs.
#
VITE_AGENT_NAVIGATOR_URL=https://<agentcore-host>/agents/agentcore_navigator/invocations
VITE_AGENT_EXTRACTOR_URL=https://<agentcore-host>/agents/agentcore_extractor/invocations
VITE_AGENT_CSV_EXPORTER_URL=https://<agentcore-host>/agents/raw_csv_exporter/invocations
VITE_AGENT_ANALYSIS_URL=https://<agentcore-host>/agents/agentcore_analysis/invocations

# ── 3. Agent Timeouts (optional) ─────────────────────────────────────────────
#
#   Milliseconds before the browser aborts a pending agent call.
#   Defaults are tuned for typical workloads.
#
# VITE_AGENT_TIMEOUT_NAVIGATOR=120000
# VITE_AGENT_TIMEOUT_EXTRACTOR=120000
# VITE_AGENT_TIMEOUT_CSV_EXPORTER=60000
# VITE_AGENT_TIMEOUT_ANALYSIS=120000
